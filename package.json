{
  "name": "fatihguzel.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "@fatihguzeldev/vemi": "0.0.2",
    "gray-matter": "4.0.3",
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "22.15.32",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.29.0",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "10.1.5",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.5.3",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
